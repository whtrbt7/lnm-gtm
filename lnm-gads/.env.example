# ─────────────────────────────────────────────────────────────────
# PREFERRED: copy google-ads.yaml.example → google-ads.yaml
# and fill in credentials there. The app loads that file first.
# These env vars are the fallback for CI/CD or Docker only.
# ─────────────────────────────────────────────────────────────────

# Google Ads API (fallback — prefer google-ads.yaml)
GOOGLE_ADS_DEVELOPER_TOKEN="your_token"
GOOGLE_ADS_CLIENT_ID="your_client_id"
GOOGLE_ADS_CLIENT_SECRET="your_secret"
GOOGLE_ADS_REFRESH_TOKEN="your_refresh_token"
MANAGER_CID="5341289102"

# PostgreSQL / Supabase (set DB_ENABLED=true to activate)
# Supabase host: db.<project-ref>.supabase.co
DB_ENABLED=false
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=require

# CallRail (Conversation Intelligence required)
CALLRAIL_API_KEY=your_callrail_api_key
CALLRAIL_ACCOUNT_ID=your_account_id

# Batch tuning
BATCH_ACCOUNT_DELAY=2.0
BATCH_QUOTA_PAUSE=60.0

# MCC account creation CLI
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_KEY=your-service-role-key
GADS_DEVELOPER_TOKEN=your-developer-token
GADS_CLIENT_ID=your-oauth-client-id
GADS_CLIENT_SECRET=your-oauth-client-secret
GADS_REFRESH_TOKEN=your-refresh-token
GADS_MCC_CID=your-mcc-customer-id-no-dashes
